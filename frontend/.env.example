# ============================================================================
# MID Manual Viewer — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development
# DO NOT commit .env.local to git
# In production, these are set via GitHub Secrets and injected at build time
# ============================================================================

# LIFF ID from LINE Developers Console
# Format: xxxxxxxxxx-xxxxxxxx
VITE_LIFF_ID=

# LINE Login Channel ID (the parent channel of the LIFF)
# Used by frontend to verify token audience
VITE_LINE_CHANNEL_ID=

# Apps Script Web App URL
# Format: https://script.google.com/macros/s/AKfycbx.../exec
VITE_APPS_SCRIPT_URL=

# Optional: enable verbose console logging in dev
VITE_DEBUG=false
