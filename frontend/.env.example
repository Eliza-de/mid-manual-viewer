# ============================================================================
# Lean Buddy By Med-healthup — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development
# DO NOT commit .env.local to git
# In production, these are set via Cloudflare Pages env / GitHub Secrets
# and injected at build time
# ============================================================================

# LIFF ID from LINE Developers Console
# Format: xxxxxxxxxx-xxxxxxxx
VITE_LIFF_ID=

# LINE Login Channel ID (the parent channel of the LIFF)
# Used by frontend to verify token audience
VITE_LINE_CHANNEL_ID=

# Cloudflare Worker API base URL
# Production: https://mid-manual-api.elizanu-de.workers.dev
VITE_API_URL=

# Optional: enable verbose console logging in dev
VITE_DEBUG=false
